# Copy this file to .env and fill in the values you need.

# Default LLM used when the request omits "model". Routing by name:
#   "leads"  → LEADS-mistral-7b via local Ollama + the LEADS-native screening
#              pipeline (highest performer in the benchmark: recall=1.000,
#              specificity=0.676, MCC=+0.260, WSS@95=0.61 on van_Dis_2020).
#              Requires Ollama running + the GGUF model pulled:
#                 ollama pull hf.co/mradermacher/leads-mistral-7b-v1-GGUF:latest
#   "claude*" → Anthropic (needs ANTHROPIC_API_KEY)
#   "gpt*"    → OpenAI    (needs OPENAI_API_KEY)
#   "gemini*" → Google    (needs GEMINI_API_KEY)
#   anything else → local Ollama (must be pulled with `ollama pull <name>`)
DEFAULT_MODEL=leads

# Optional: override the LEADS GGUF name or score threshold.
# LEADS_MODEL_NAME=hf.co/mradermacher/leads-mistral-7b-v1-GGUF:latest
# LEADS_SCORE_THRESHOLD=0.20

# AI provider keys (only what you intend to use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional literature-source API keys
SEMANTIC_SCHOLAR_KEY=
CORE_API_KEY=

# ── Elsevier (Embase + Scopus) ──────────────────────────────────────────────
#
# TWO modes — use whichever fits your deployment:
#
# Mode A: One-click OAuth (RECOMMENDED for multi-user deployments)
#   Register this platform as an app once at https://dev.elsevier.com/
#   Users then connect via a popup: Elsevier → "Sign in with institution" →
#   UCSF MyAccess → done.  No per-user API key needed.
#
ELSEVIER_OAUTH_CLIENT_ID=
ELSEVIER_OAUTH_CLIENT_SECRET=
# Public URL the backend is reachable at (used as OAuth redirect URI).
APP_BASE_URL=http://localhost:8000
#
# Mode B: Static API key (simpler for single-user / local installs)
#   1. Register at https://dev.elsevier.com/ with your @ucsf.edu email.
#   2. Copy your API key and the institutional token from the portal.
#
ELSEVIER_API_KEY=
ELSEVIER_INST_TOKEN=

# Required by NCBI Entrez / PubMed AND by the Unpaywall OA-PDF lookup that
# powers Full-Text Acquisition. Unpaywall rejects placeholder addresses
# (e.g. "researcher@example.com" or "test@test.com") with HTTP 422 — use a
# real email address you control.
ENTREZ_EMAIL=your.email@example.com

# Extra CORS origins (comma-separated). Vite dev on 5173 is allowed by default.
CORS_ORIGINS=

# Screening parallelism (defaults to 16)
PARALLEL_SCREENING_WORKERS=16
PARALLEL_AGENT_WORKERS=16
