# Copy to .env.local and fill in. Vite-prefixed VITE_* vars are exposed to the
# browser; do not put any secret values here.

# Supabase project (public anon key only — never the service-role key)
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# Backend (FastAPI) base URL if not co-hosted with Vite. Leave blank to use the
# Vite dev-server proxy at /api -> http://localhost:8000.
# VITE_API_BASE=http://localhost:8000
